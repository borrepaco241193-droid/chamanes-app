# ============================================================
# CHAMANES APP — Environment Variables Template
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# ── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8081

# ── Database (Railway PostgreSQL) ───────────────────────────
# Get this from Railway → your project → PostgreSQL service → Variables
DATABASE_URL=postgresql://postgres:password@localhost:5432/chamanes_dev

# ── Redis (Railway Redis) ───────────────────────────────────
# Get this from Railway → your project → Redis service → Variables
REDIS_URL=redis://localhost:6379

# ── Authentication ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_hex_secret_here
JWT_REFRESH_SECRET=another_64_char_random_hex_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Stripe (Payments) ───────────────────────────────────────
# Get from: stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── Resend (Emails) ─────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@chamanes.app

# ── Cloudflare R2 (File Storage) ────────────────────────────
# Get from: Cloudflare Dashboard → R2 → API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=chamanes-uploads
R2_PUBLIC_URL=https://your-bucket.r2.dev

# ── Sentry (Error Monitoring) ───────────────────────────────
# Get from: sentry.io → Project → Settings → SDK Setup
SENTRY_DSN=https://your_key@o123.ingest.sentry.io/456

# ── Firebase (Push Notifications) ───────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_key_here\n-----END PRIVATE KEY-----\n"

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=60000

# ── Encryption ──────────────────────────────────────────────
# Used for QR code signing — generate same way as JWT_SECRET
ENCRYPTION_KEY=your_32_char_encryption_key_here
