{
  "expo": {
    "name": "Chamanes",
    "slug": "chamanes-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "chamanes",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.chamanes.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Chamanes uses the camera to scan visitor QR codes at the gate.",
        "NSPhotoLibraryUsageDescription": "Chamanes accesses your photos to set your profile picture.",
        "NSFaceIDUsageDescription": "Chamanes uses Face ID for secure authentication.",
        "NSLocationWhenInUseUsageDescription": "Chamanes may use your location for staff check-in verification."
      }
    },
    "android": {
      "package": "app.chamanes.mobile",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "USE_FINGERPRINT",
        "USE_BIOMETRIC",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Chamanes uses the camera to scan QR codes at the gate."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#6366F1",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Chamanes uses Face ID for secure authentication."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "apiUrl": "https://chamanes-app-production.up.railway.app",
      "router": {},
      "eas": {
        "projectId": "54edd6d7-1120-4360-a153-154b1f178ba5"
      }
    },
    "owner": "borre241193"
  }
}
